# Public application configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DISPLAY_CURRENCY=GHS
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SIGNUP_FEE_GHS=50

# Supabase (create a project, then copy its public URL and publishable key)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only admin operations
ADMIN_SIGNED_URL_TTL_SECONDS=300
APP_VERSION=
# Development-only empty admin preview. Ignored in production.
ADMIN_DEMO_PREVIEW=false

# Development-only local sub-admin login. Ignored in production.
LOCAL_SUB_ADMIN_PREVIEW=false
LOCAL_SUB_ADMIN_USERNAME=
LOCAL_SUB_ADMIN_PASSWORD=
LOCAL_SUB_ADMIN_SESSION_SECRET=

# Server-only payment configuration (Paystack Standard Checkout)
PAYSTACK_SECRET_KEY=

# Server-only referral attribution and commission policy
# Generate at least 32 random characters, for example: openssl rand -base64 48
REFERRAL_ATTRIBUTION_SECRET=
REFERRAL_ATTRIBUTION_DAYS=30
REFERRAL_COMMISSION_HOLD_DAYS=0

# Server-only analysis adapter configuration
# Supported values:
# - demo: browser OCR of Instant Virtuals screenshots + favorite win picks (falls back to illustrative demo)
# - remote-http: trusted external vision provider
ANALYSIS_PROVIDER=demo
ANALYSIS_PROVIDER_API_KEY=
ANALYSIS_PROVIDER_ENDPOINT=

# Optional distributed rate limiter integration
RATE_LIMIT_PROVIDER=
RATE_LIMIT_API_URL=
RATE_LIMIT_API_TOKEN=
